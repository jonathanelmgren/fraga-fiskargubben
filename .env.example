# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fiskargubben

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-base64-secret
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — Google Cloud Console → Credentials → OAuth client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
