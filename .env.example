# Postgres connection string
# Local dev DB runs via `docker compose up -d` (PostGIS) on port 5433 — see compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/fiskargubben

# Anthropic API key — Claude Haiku 4.5 (extractor) + Sonnet 4.6 (advice)
ANTHROPIC_API_KEY=

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-base64-secret
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — Google Cloud Console → Credentials → OAuth client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Entra OAuth — App registration → Certificates & secrets
# Redirect URI (Web platform): http://localhost:3000/api/auth/callback/microsoft
# tenantId "common" is hardcoded in auth.ts (any work/school/personal account)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Resend — transactional mail (email verification). https://resend.com/api-keys
# Optional: unset in dev/CI logs the verification URL to console instead.
# EMAIL_FROM domain must be verified in the Resend dashboard.
# RESEND_API_KEY=
EMAIL_FROM=Fiskargubben <noreply@fragagubben.se>

# ─── ETL data-source credentials (import-time only; never on the request path) ──
# The ETL scripts (pnpm etl:*) load this file via `tsx --env-file-if-exists=.env`,
# so put DATABASE_URL + these keys in your real .env. All are import-only —
# the runtime app never reads them.

# VISS apikey — SVAR/lakes seed (pnpm etl:svar).
# The open Vatteninformationssystem Sverige water register (Länsstyrelserna).
# Register for a free apikey at https://viss.lansstyrelsen.se/api
# Optional override: VISS_API_URL (defaults to https://viss.lansstyrelsen.se/api).
VISS_APIKEY=

# SLU Miljödata-MVM public ticket — water colour/Secchi seed (pnpm etl:mvm).
# How to obtain: register as a web-service user at Artdatabanken UserAdmin
# (https://accounts.artdatabanken.se), then activate the ticket under
# "Mina sidor" in Miljödata-MVM (https://miljodata.slu.se/mvm/).
# No approval needed; the ticket is issued immediately after activation.
# Optional overrides: MVM_BASE_URL, MVM_MAX_SAMPLES (cap for the ~500MB export).
MVM_TICKET=

# Lantmäteriet Geotorget download API — full lake coverage ETL (pnpm etl:lakes).
# The lake universe (Topografi vektor, CC0) is ordered once in Geotorget; the
# OrderID appears under Mitt konto → Ärenden. Credentials come from a system
# account created in Lantmäteriet's API-Portal (HTTP Basic by default).
# Import-time only; the runtime app never reads these.
LM_ORDER_ID=
LM_USERNAME=
LM_PASSWORD=
# Optional overrides: LM_ORDER_BASE_URL (default https://api.lantmateriet.se),
# LM_DOWNLOAD_BASE_URL (default https://download-geotorget.lantmateriet.se).

# Admin allowlist for the /admin/analytics dashboard (ADR-0005).
# Comma-separated email addresses matched (case-insensitively) against the
# signed-in Better Auth account. Empty = no admins; the dashboard 404s for
# everyone. There is no admin/role column yet — this env allowlist is the gate.
ADMIN_EMAILS=
