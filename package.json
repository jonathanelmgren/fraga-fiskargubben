{
  "name": "fiskargubben",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "biome": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:fix:unsafe": "biome check . --write --unsafe",
    "biome:ci": "biome ci .",
    "test": "vitest run",
    "test:changed": "vitest run --changed ${VITEST_CHANGED_REF:-HEAD~1}",
    "test:watch": "vitest",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "rev-dep": "rev-dep config run",
    "commitlint": "commitlint",
    "ts:check": "tsgo --noEmit",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "29.1.1",
    "lefthook": "2.1.9",
    "rev-dep": "2.16.1",
    "tailwindcss": "^4.3.1",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
